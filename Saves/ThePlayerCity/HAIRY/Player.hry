
Object "Plr_Male_Warrior" "Plr_Mage" "Plr_Rogue" 
{
    OnOpenInventory
    {
        // Open the default player container
        OpenContainer object
    }

    OnNew
    {
        // Spawn basic starting kit
        Object dagger = Create TYPE_DAGGER
        Object gold   = Create TYPE_GOLD
    }
}
